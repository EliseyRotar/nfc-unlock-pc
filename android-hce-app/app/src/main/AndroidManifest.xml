<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required to expose a Host Card Emulation service -->
    <uses-feature
        android:name="android.hardware.nfc.hce"
        android:required="true" />
    <uses-permission android:name="android.permission.NFC" />

    <application
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:theme="@style/Theme.Material3.DayNight">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          HostApduService that answers the SELECT AID command sent by
          src/nfc_unlock/reader.py (get_hce_token) with this device's
          enrollment token. android:exported must be true so the NFC
          stack can bind to it; requireDeviceUnlock=false so it also
          works while the PC's lock screen is what you're trying to
          unlock (the phone itself may well be unlocked already, but we
          don't want to require it).
        -->
        <service
            android:name=".HceService"
            android:exported="true"
            android:permission="android.permission.BIND_NFC_SERVICE">
            <intent-filter>
                <action android:name="android.nfc.cardemulation.action.HOST_APDU_SERVICE" />
            </intent-filter>
            <meta-data
                android:name="android.nfc.cardemulation.host_apdu_service"
                android:resource="@xml/apduservice" />
        </service>

    </application>
</manifest>
